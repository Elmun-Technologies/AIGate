# Local development configuration
# Copy from .env.example and override as needed

POSTGRES_DB=agent
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
DATABASE_URL=postgresql://agent:agent@postgres:5432/agent

REDIS_URL=redis://redis:6379/0

OPENAI_API_KEY=test

APP_ENV=dev
LOG_LEVEL=debug

# Dev thresholds (lower than production for testing)
SPEND_DAILY_THRESHOLD_USD=50
SPEND_SPIKE_PERCENT=200
AI_DEFAULT_ORGANIZATION_ID=11111111-1111-1111-1111-111111111111
AI_DAILY_SPIKE_MULTIPLIER=2.0

# Runtime token
RUNTIME_TOKEN_TTL_SECONDS=300

# Dev allowlist
DESTINATION_ALLOWLIST=api.partner.example,api.trusted.example,localhost:9000,127.0.0.1:9000

# Optional services (disabled for faster dev startup)
OPA_URL=
ANCHOR_BACKEND_URL=
MIXPANEL_TOKEN=
STRIPE_SECRET_KEY=

# Demo login (seeded by backend on startup)
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=Admin123!
